{
	admin off
}

(local_tls) {
	tls internal
	encode zstd gzip
	header {
		Strict-Transport-Security "max-age=31536000"
		X-Content-Type-Options "nosniff"
		Referrer-Policy "no-referrer"
		Permissions-Policy "camera=(), microphone=(), geolocation=()"
		Content-Security-Policy "default-src 'self'; img-src 'self' data:; style-src 'self' 'unsafe-inline'; script-src 'self' 'unsafe-inline'; connect-src 'self'; frame-ancestors 'none'; base-uri 'self'; form-action 'self'"
		-Server
	}
}

home.{$HOME_DOMAIN} {
	import local_tls
	basic_auth {
		roma {$DASHBOARD_PASSWORD_HASH}
	}
	reverse_proxy dashboard:3000 {
		header_up X-Household-User {http.auth.user.id}
	}
}

mealie.{$HOME_DOMAIN} {
	import local_tls
	reverse_proxy mealie:9000
}

tasks.{$HOME_DOMAIN} {
	import local_tls
	reverse_proxy vikunja:3456
}

things.{$HOME_DOMAIN} {
	import local_tls
	reverse_proxy homebox:7745
}

vault.{$HOME_DOMAIN} {
	import local_tls
	reverse_proxy vaultwarden:80
}

status.{$HOME_DOMAIN} {
	import local_tls
	reverse_proxy uptime-kuma:3001
}

cinema.{$HOME_DOMAIN} {
	import local_tls
	reverse_proxy jellyfin:8096
}

assistant.{$HOME_DOMAIN} {
	import local_tls
	reverse_proxy home-assistant:8123
}
