# Copy to .env on the Debian server. Never commit the real file.
TZ=Europe/Kyiv
HOME_DOMAIN=home.arpa
LAN_IP=192.168.31.163
UPSTREAM_DNS=192.168.31.1
CADDY_HTTP_PORT=8088
CADDY_HTTPS_PORT=443
PUID=1000
PGID=1000

# Bootstrap tags. Resolve and pin tested immutable digests before production.
CADDY_IMAGE=caddy:2.10.2-alpine
COREDNS_IMAGE=coredns/coredns:1.14.4
POSTGRES_IMAGE=postgres:17.6-alpine
MEALIE_IMAGE=ghcr.io/mealie-recipes/mealie:latest
VIKUNJA_IMAGE=vikunja/vikunja:latest
HOMEBOX_IMAGE=ghcr.io/sysadminsmedia/homebox:latest
VAULTWARDEN_IMAGE=vaultwarden/server:latest-alpine
UPTIME_KUMA_IMAGE=louislam/uptime-kuma:latest
JELLYFIN_IMAGE=jellyfin/jellyfin:latest
HOME_ASSISTANT_IMAGE=ghcr.io/home-assistant/home-assistant:stable
MEDIA_ROOT=/srv/media
RENDER_GID=109

# Generate each value independently with: openssl rand -base64 36
MEALIE_POSTGRES_PASSWORD=CHANGE_ME
VIKUNJA_POSTGRES_PASSWORD=CHANGE_ME
VIKUNJA_SECRET=CHANGE_ME
HOMEBOX_API_KEY_PEPPER=CHANGE_ME

# Dashboard integrations. Create API tokens in each service after first login.
MEALIE_TOKEN=
MEALIE_SHOPPING_LIST_ID=
VIKUNJA_TOKEN=
VIKUNJA_PROJECT_ID=
HOMEBOX_TOKEN=
JELLYFIN_TOKEN=
HOME_ASSISTANT_TOKEN=
HA_MOVIE_SCENE=

# Encrypted off-site copy. Use a mounted external path or user@host:/path.
OFFSITE_BACKUP_TARGET=
OFFSITE_PASSPHRASE_FILE=

# Dashboard household authentication. Generate with: openssl rand -base64 36
DASHBOARD_SESSION_SECRET=CHANGE_ME
DASHBOARD_USERS=roma
DASHBOARD_PASSWORD_HASH=CHANGE_ME
