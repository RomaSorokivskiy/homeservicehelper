# Copy to .env on the Debian server. Never commit the real file.
TZ=Europe/Kyiv
HOME_DOMAIN=home.arpa
PUID=1000
PGID=1000

# Bootstrap tags. Resolve and pin tested immutable digests before production.
CADDY_IMAGE=caddy:2.10.2-alpine
POSTGRES_IMAGE=postgres:17.6-alpine
MEALIE_IMAGE=ghcr.io/mealie-recipes/mealie:latest
VIKUNJA_IMAGE=vikunja/vikunja:latest
HOMEBOX_IMAGE=ghcr.io/sysadminsmedia/homebox:latest
VAULTWARDEN_IMAGE=vaultwarden/server:latest-alpine
UPTIME_KUMA_IMAGE=louislam/uptime-kuma:latest

# Generate each value independently with: openssl rand -base64 36
MEALIE_POSTGRES_PASSWORD=CHANGE_ME
VIKUNJA_POSTGRES_PASSWORD=CHANGE_ME
VIKUNJA_JWT_SECRET=CHANGE_ME
